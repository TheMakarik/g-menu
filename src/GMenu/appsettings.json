{
    "Configuration": {
        "Directory": "/g-menu",
        "ConfigFileName": "g-menu.json",
        "ValidIconExtensions": [
            ".svg",
            ".png",
            ".jpg",
            ".jpeg",
            ".xpm"
        ]
    },
    "Logging": {
        "OutputTemplate": "[{Level:u3}] [{Timestamp:yyyy-MM-dd HH:mm}] [{ThreadId}] {Message:lj}{NewLine}{Exception}",
        "LogsDirectory": "logs",
        "LogFileNamePrefix": "g-menu-log__",
        "RollingInterval": "Day"
    },
    "Localization": {
        "LocalizationPath": "Localization",
        "DefaultCulture": "eng-US",
        "SupportedCultures": [
            "ru-Ru",
            "eng-US"
        ],
        "NotFoundValue": "????"
    },
    "Ui": {
        "DefaultJsonNamingPolicy": "CamelCase",
        "UncategorizedCategory": "Uncategorized",
        "DragDropWaitTimeMs": 30
    },
    "Core": {
        "AboutDesktopFiles": "https://linuxvox.com/blog/linux-desktop-file/",
        "Version": "2026.0.0",
        "Github": "https://github.com/TheMakarik/g-menu"
    },
    "Linux": {
        "ShellScripts": {
            "ExecuteWithPolicyKit": "Shell/gmenu-run-desktop-file-exec-wilth-policykit-1.sh"
        },
        "SupportedTerminals": [
            {
                "Name": "xdg-terminal-exec",
                "Command": "{0}"
            },
            {
                "Name": "gnome-terminal",
                "Command": "-- sh -c \"{0}; exec sh\""
            },
            {
                "Name": "konsole",
                "Command": "-e sh -c \"{0}; exec sh\""
            },
            {
                "Name": "xfce4-terminal",
                "Command": "-e \"sh -c '{0}; exec sh'\""
            },
            {
                "Name": "mate-terminal",
                "Command": "-e \"sh -c '{0}; exec sh'\""
            },
            {
                "Name": "lxterminal",
                "Command": "-e sh -c \"{0}; exec sh\""
            },
            {
                "Name": "terminator",
                "Command": "-x sh -c \"{0}; exec sh\""
            },
            {
                "Name": "alacritty",
                "Command": "-e sh -c \"{0}; exec sh\""
            },
            {
                "Name": "kitty",
                "Command": "sh -c \"{0}; exec sh\""
            },
            {
                "Name": "wezterm",
                "Command": "start -- sh -c \"{0}; exec sh\""
            },
            {
                "Name": "foot",
                "Command": "sh -c \"{0}; exec sh\""
            },
            {
                "Name": "ghostty",
                "Command": "-e sh -c \"{0}; exec sh\""
            },
            {
                "Name": "xterm",
                "Command": "-e sh -c \"{0}; exec sh\""
            }
        ]
    },
