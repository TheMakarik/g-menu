<rx:ReactiveUserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="GMenu.Views.DesktopFilesTreeView"
    x:DataType="vm:DesktopFilesTreeViewModel"
    x:TypeArguments="vm:DesktopFilesTreeViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:GMenu.Views.Controls"
    xmlns:converters="clr-namespace:GMenu.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rx="http://reactiveui.net"
    xmlns:thisNamespace="clr-namespace:GMenu.Views"
    xmlns:vm="using:GMenu.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        Theme="{StaticResource MaterialModernScrollViewer}"
        VerticalScrollBarVisibility="Auto">

        <Panel>
            <TreeView
                IsVisible="{Binding SearchText, Converter={converters:IsStringNullOrWhitespaceConverter}}"
                ItemsSource="{Binding Children}"
                Name="DesktopFilesTreeViewControl"
                SelectedItem="{Binding SelectedItem}">

                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="DragDrop.AllowDrop" Value="True" />
                    </Style>


                </TreeView.Styles>

                <Interaction.Behaviors>
                    <EventTriggerBehavior EventName="Loaded">
                        <InvokeCommandAction Command="{Binding LoadDesktopFilesCommand}" />
                    </EventTriggerBehavior>
                </Interaction.Behaviors>

                <TreeView.DataTemplates>

                    <TreeDataTemplate DataType="vm:TreeViewModelCategory" ItemsSource="{Binding Children}">
                        <StackPanel
                            Height="{Binding Height, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                            Margin="-10,0,0,0"
                            Orientation="Horizontal">
                            <ContentControl
                                Content="{Binding CategoryName, Converter={converters:CategoryStringToMaterialIconConverter}}"
                                Height="{StaticResource IconInTreeViewSize}"
                                Width="{StaticResource IconInTreeViewSize}"
                                x:Name="IconCategoryControl" />
                            <Label Content="{Binding CategoryName, Converter={converters:TryLocalizeValueConverter}}">
                                <Label.Margin>
                                    <Binding ElementName="IconCategoryControl" Path="Content">
                                        <Binding.Converter>
                                            <converters:MoveControlToLeftIfImageSourceOrMaterialIconIsNullConverter />
                                        </Binding.Converter>
                                        <Binding.ConverterParameter>
                                            <Thickness>0, 3, 0, 0</Thickness>
                                        </Binding.ConverterParameter>
                                    </Binding>
                                </Label.Margin>
                            </Label>
                        </StackPanel>
                    </TreeDataTemplate>

                    <TreeDataTemplate DataType="vm:TreeViewModelDesktopFile" ItemsSource="{Binding Children}">
                        <Border
                            DragDrop.AllowDrop="True"
                            Height="{Binding Height, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                            Loaded="LoadContextMenu"
                            Width="{Binding Width, RelativeSource={RelativeSource AncestorType=TreeView}}">

                            <Border.Resources>
                                <ContextMenu x:Key="{x:Static thisNamespace:DesktopFilesTreeView.DesktopFileContextMenuResourceKey}">

                                    <MenuItem
                                        Command="{Binding RunDesktopFileCommand}"
                                        Header="{Binding LocalizationProvider[RunDesktopFile]}"
                                        Icon="{icons:MaterialIconExt Kind=PlayBox}" />
                                    <MenuItem
                                        Command="{Binding SudoRunDesktopFileCommand}"
                                        Header="{Binding LocalizationProvider[SudoRunDesktopFile]}"
                                        Icon="{icons:MaterialIconExt Kind=PlayBoxEditOutline}" />
                                    <MenuItem Header="{Binding LocalizationProvider[RenameDesktopFile]}" Icon="{icons:MaterialIconExt Kind=RenameBox}" />
                                    <MenuItem
                                        Command="{Binding ShowInTextEditorCommand}"
                                        Header="{Binding LocalizationProvider[ShowInTextEditor]}"
                                        Icon="{icons:MaterialIconExt Kind=FileTextEdit}" />
                                    <MenuItem
                                        Command="{Binding RemoveSelfCommand}"
                                        CommandParameter="{Binding}"
                                        Header="{Binding LocalizationProvider[Remove]}"
                                        Icon="{icons:MaterialIconExt Kind=TrashCan}" />
                                </ContextMenu>
                            </Border.Resources>

                            <Grid
                                ColumnDefinitions="Auto, *"
                                Margin="-25,0,0,0"
                                VerticalAlignment="Center">
                                <controls:DesktopFileImage
                                    BorderThickness="3"
                                    Grid.Column="0"
                                    Height="{StaticResource IconInTreeViewSize}"
                                    SourceString="{Binding IconPath}"
                                    Width="{StaticResource IconInTreeViewSize}"
                                    x:Name="DesktopFileImage" />

                                <Label
                                    Content="{Binding Name}"
                                    Grid.Column="1"
                                    VerticalAlignment="Center">
                                    <Label.Margin>
                                        <Binding ElementName="DesktopFileImage" Path="ActualSource">
                                            <Binding.Converter>
                                                <converters:MoveControlToLeftIfImageSourceOrMaterialIconIsNullConverter />
                                            </Binding.Converter>
                                            <Binding.ConverterParameter>
                                                <Thickness>6, 3, 0, 0</Thickness>
                                            </Binding.ConverterParameter>
                                        </Binding>
                                    </Label.Margin>
                                </Label>
                            </Grid>
                        </Border>
                    </TreeDataTemplate>

                </TreeView.DataTemplates>
            </TreeView>
            <ListBox
                IsVisible="{Binding IsVisible, ElementName=DesktopFilesTreeViewControl, Converter={converters:ReverseBooleanConverter}}"
                ItemsSource="{Binding SearchResults}"
                Margin="20,0,0,0"
                Name="DesktopFilesListBoxControl"
                SelectedItem="{Binding SelectedItem}">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            ColumnDefinitions="Auto, *"
                            Loaded="LoadContextMenu"
                            VerticalAlignment="Center">

                            <Grid.Resources>
                                <ContextMenu x:Key="{x:Static thisNamespace:DesktopFilesTreeView.DesktopFileContextMenuResourceKey}">
                                    <MenuItem
                                        Command="{Binding RunDesktopFileCommand}"
                                        Header="{Binding LocalizationProvider[RunDesktopFile]}"
                                        Icon="{icons:MaterialIconExt Kind=PlayBox}" />
                                    <MenuItem
                                        Command="{Binding SudoRunDesktopFileCommand}"
                                        Header="{Binding LocalizationProvider[SudoRunDesktopFile]}"
                                        Icon="{icons:MaterialIconExt Kind=PlayBoxEditOutline}" />
                                    <MenuItem Header="{Binding LocalizationProvider[RenameDesktopFile]}" Icon="{icons:MaterialIconExt Kind=RenameBox}" />
                                    <MenuItem
                                        Command="{Binding ShowInTextEditorCommand}"
                                        Header="{Binding LocalizationProvider[ShowInTextEditor]}"
                                        Icon="{icons:MaterialIconExt Kind=FileTextEdit}" />
                                    <MenuItem
                                        Command="{Binding RemoveSelfCommand}"
                                        CommandParameter="{Binding}"
                                        Header="{Binding LocalizationProvider[Remove]}"
                                        Icon="{icons:MaterialIconExt Kind=TrashCan}" />
                                </ContextMenu>
                            </Grid.Resources>


                            <controls:DesktopFileImage
                                BorderThickness="3"
                                Grid.Column="0"
                                Height="{StaticResource IconInTreeViewSize}"
                                SourceString="{Binding IconPath}"
                                Width="{StaticResource IconInTreeViewSize}"
                                x:Name="DesktopFileImage" />

                            <Label
                                Content="{Binding Name}"
                                Grid.Column="1"
                                VerticalAlignment="Center">
                                <Label.Margin>
                                    <Binding ElementName="DesktopFileImage" Path="ActualSource">
                                        <Binding.Converter>
                                            <converters:MoveControlToLeftIfImageSourceOrMaterialIconIsNullConverter />
                                        </Binding.Converter>
                                        <Binding.ConverterParameter>
                                            <Thickness>6, 3, 0, 0</Thickness>
                                        </Binding.ConverterParameter>
                                    </Binding>
                                </Label.Margin>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Panel>


    </ScrollViewer>


</rx:ReactiveUserControl>
