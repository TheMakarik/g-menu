<rx:ReactiveUserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="GMenu.Views.DesktopFilesTreeView"
    x:DataType="vm:DesktopFilesTreeViewModel"
    x:TypeArguments="vm:DesktopFilesTreeViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rx="http://reactiveui.net"
    xmlns:vm="using:GMenu.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <TreeView ItemsSource="{Binding Children}">

        <Interaction.Behaviors>
            <EventTriggerBehavior EventName="Loaded">
                <InvokeCommandAction Command="{Binding LoadDesktopFilesCommand}" />
            </EventTriggerBehavior>
        </Interaction.Behaviors>

        <TreeDataTemplate>
            <DataTemplates>
                <DataTemplate DataType="vm:TreeViewDirectoriesViewModel">
                    <Label Content="{Binding Path}" />
                </DataTemplate>
            </DataTemplates>
        </TreeDataTemplate>
    </TreeView>

</rx:ReactiveUserControl>
