<rx:ReactiveWindow
    CanMaximize="False"
    CanMinimize="False"
    Height="300"
    Name="Window"
    Title="{Binding LocalizationProvider[AddCategory]}"
    Width="400"
    mc:Ignorable="d"
    x:Class="GMenu.Views.AddNewCategoryWindow"
    x:DataType="vm:AddNewCategoryWindowViewModel"
    x:TypeArguments="vm:AddNewCategoryWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
    xmlns:converters="clr-namespace:GMenu.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rx="clr-namespace:ReactiveUI.Avalonia;assembly=ReactiveUI.Avalonia"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:vm="using:GMenu.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Closed">
            <InvokeCommandAction Command="{Binding ClearSearchTextAndIconsCommand}" />
        </EventTriggerBehavior>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadIconsKindCommand}" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

        <Grid Margin="10" RowDefinitions="Auto, Auto, Auto, Auto">
            <Grid ColumnDefinitions="Auto, *" Grid.Row="0">
                <icons:MaterialIcon
                    Grid.Column="0"
                    Height="30"
                    Kind="Rename"
                    Loaded="LoadForegroundBindingsForLocalizedCategory"
                    Name="LocalizedCategoryIcon"
                    Width="30" />
                <TextBox
                    Grid.Column="1"
                    Margin="10,0,10,0"
                    Name="LocalizedCategoryTextBox"
                    PlaceholderText="{Binding LocalizationProvider[CategoryName]}"
                    Text="{Binding LocalizedCategory}" />
            </Grid>
            <Grid ColumnDefinitions="Auto, *" Grid.Row="1">
                <icons:MaterialIcon
                    Grid.Column="0"
                    Height="30"
                    Kind="Category"
                    Loaded="LoadForegroundBindingsForUnlocalizedCategory"
                    Name="UnlocalizedCategoryIcon"
                    Width="30" />
                <TextBox
                    Grid.Column="1"
                    Margin="10,0,10,0"
                    Name="UnlocalizedCategoryTextBox"
                    PlaceholderText="{Binding LocalizationProvider[UnlocalizedCategoryName]}"
                    Text="{Binding UnlocalizedCategory}">

                    <TextBox.InnerLeftContent>
                        <TextBlock
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            VerticalAlignment="Center">
                            X-
                        </TextBlock>
                    </TextBox.InnerLeftContent>
                </TextBox>
            </Grid>
            <Grid
                ColumnDefinitions="Auto, Auto"
                Grid.Row="2"
                Margin="0,15,0,0">
                <TextBlock
                    Classes="outline"
                    Grid.Column="0"
                    Margin="0,7,0,0"
                    Text="{Binding LocalizationProvider[CategoryIcon]}"
                    TextAlignment="Center" />
                <Button
                    Background="{Binding #Window.Background}"
                    BorderThickness="1"
                    Classes="outline"
                    Click="ToggleMaterialIconsPopup"
                    Grid.Column="1"
                    Height="30"
                    HorizontalContentAlignment="Center"
                    Margin="10,0,0,0"
                    Name="TogglePopupButton"
                    VerticalContentAlignment="Center"
                    Width="30">
                    <Button.Content>
                        <Panel>
                            <ContentControl
                                Content="{Binding IconKind, Converter={converters:StringToMaterialIconConverter}}"
                                Height="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="30" />
                            <Popup
                                Height="400"
                                IsLightDismissEnabled="True"
                                Name="MaterialIconsPopup"
                                Placement="Top"
                                PlacementTarget="{Binding #TogglePopupButton}"
                                Width="400">
                                <Border BorderThickness="1">
                                    <Grid RowDefinitions="Auto, *">
                                        <TextBox
                                            Classes="outline dense"
                                            Grid.Row="0"
                                            Loaded="LoadInnerIconForeground"
                                            Margin="20"
                                            Text="{Binding SearchIconText}"
                                            Theme="{StaticResource OutlineTextBox}"
                                            UseFloatingPlaceholder="True"
                                            assists:TextFieldAssist.Label="{Binding LocalizationProvider[Search]}">
                                            <TextBox.InnerRightContent>
                                                <icons:MaterialIcon
                                                    Height="30"
                                                    Kind="Search"
                                                    Width="30" />
                                            </TextBox.InnerRightContent>
                                        </TextBox>
                                        <ScrollViewer Grid.Row="1">
                                            <ItemsRepeater
                                                HorizontalAlignment="Center"
                                                ItemsSource="{Binding Icons}"
                                                x:DataType="vm:AddNewCategoryWindowViewModel"
                                                x:Name="MaterialIconsControl">
                                                <ItemsRepeater.Layout>
                                                    <UniformGridLayout MaximumRowsOrColumns="12" />
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="system:String">
                                                        <Button
                                                            BorderBrush="Transparent"
                                                            Classes="outline"
                                                            Click="SetIconKind"
                                                            CommandParameter="{Binding}"
                                                            Height="30"
                                                            Margin="2"
                                                            Padding="0"
                                                            ToolTip.Tip="{Binding}"
                                                            Width="30">
                                                            <ContentControl Content="{Binding Converter={converters:StringToMaterialIconConverter}, ConverterParameter=25}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Panel>
                    </Button.Content>
                </Button>
            </Grid>
            <Button
                Command="{Binding CreateNewCategoryCommand}"
                Content="{Binding LocalizationProvider[Create]}"
                Grid.Row="3"
                IsEnabled="{Binding HasErrors, Converter={converters:ReverseBooleanConverter}}"
                Margin="50,30,20,20" />
        </Grid>
    </ScrollViewer>

</rx:ReactiveWindow>
